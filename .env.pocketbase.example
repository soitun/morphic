##############################################################################
# Morphic Configuration with PocketBase v0.36.7
##############################################################################

# =============================================================================
# REQUIRED CONFIGURATION
# These settings are essential for application to function
# =============================================================================

# -----------------------------------------------------------------------------
# PocketBase Configuration (Required)
# -----------------------------------------------------------------------------
# PocketBase server URL
POCKETBASE_URL=http://localhost:8090

# -----------------------------------------------------------------------------
# Database Configuration (Required)
# -----------------------------------------------------------------------------
# PostgreSQL connection string (supports Neon, Supabase, or standard PostgreSQL)
DATABASE_URL=postgresql://morphic:morphic@postgres:5432/morphic

# -----------------------------------------------------------------------------
# AI Provider Configuration (At least one required)
# -----------------------------------------------------------------------------
# Option 1: OpenAI
OPENAI_API_KEY=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

# -----------------------------------------------------------------------------
# Search Provider Configuration (Required)
# -----------------------------------------------------------------------------
# Tavily Search (Default)
TAVILY_API_KEY=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

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================

# Enable PocketBase authentication
ENABLE_AUTH=true
ANONYMOUS_USER_ID=anonymous-user

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================

# PostgreSQL credentials for Docker Compose
POSTGRES_USER=morphic
POSTGRES_PASSWORD=morphic
POSTGRES_DB=morphic
POSTGRES_PORT=5432

# Database SSL disabled for local Docker
DATABASE_SSL_DISABLED=true

# =============================================================================
# POCKETBASE SPECIFIC CONFIGURATION
# =============================================================================

# PocketBase admin setup (first time only)
# After first run, access http://localhost:8090/_/ to set up admin account
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=admin123456
